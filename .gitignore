# Gradle and build folders
.gradle/
/build/
*/build/
*/*/build/
*/*/*/build/

# Local configuration files (contains your local SDK path - do not commit!)
local.properties

# Android Studio / IntelliJ IDEA specific files
.idea/
*.iml
*.ipr
*.iws
/.idea/workspace.xml
/.idea/tasks.xml
/.idea/gradle.xml
/.idea/assetWizardSettings.xml
/.idea/dictionaries
/.idea/libraries
/.idea/caches
/.idea/modules.xml
/.idea/navEditor.xml

# macOS specific hidden files
.DS_Store
.AppleDouble
.LSOverride

# Built application files
*.apk
*.aar
*.ap_
*.aab

# Java class files and Dalvik VM files
*.class
*.dex

# Log Files
*.log

# Keystore files (Keep your signing keys secure!)
*.jks
*.keystore